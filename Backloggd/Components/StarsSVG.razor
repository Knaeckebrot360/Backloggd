@using System.Globalization

@for (int i = 1; i <= 5; i++)
{
    var fill = Math.Min(1, Math.Max(0, Score - (i - 1))) * 100;
    var gradId = $"sg{i}{Id}";
    <svg width="14" height="14" viewBox="0 0 12 12" style="display:inline-block;overflow:visible;">
        <defs>
            <linearGradient id="@gradId" x1="0" x2="1" y1="0" y2="0">
                <stop offset="@(fill.ToString("F1", CultureInfo.InvariantCulture))%" stop-color="#EF9F27"/>
                <stop offset="@(fill.ToString("F1", CultureInfo.InvariantCulture))%" stop-color="#D3D1C7"/>
            </linearGradient>
        </defs>
        <path d="M6,1.5 L7.27,4.64 L10.5,4.64 L7.95,6.61 L8.9,9.75 L6,7.9 L3.1,9.75 L4.05,6.61 L1.5,4.64 L4.73,4.64 Z" fill="url(#@gradId)"/>
    </svg>
}

@code {
    [Parameter] public double Score { get; set; }
    [Parameter] public string Id { get; set; } = Guid.NewGuid().ToString("N")[..6];
}
