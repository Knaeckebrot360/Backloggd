  window.scrollTo(0, 0);
}

function openGame(idx) {
  const g = games[idx];
  document.getElementById("homePage").style.display = "none";
  document.getElementById("detailPage").style.display = "";
  window.scrollTo(0, 0);

  const rank = games.slice().sort((a,b) => b.score - a.score).findIndex(x => x.title === g.title) + 1;

  const reviews = g.reviews.map(r => `
    <div class="review">
      <div class="review-top">
        <div class="avatar">${r.name[0]}</div>
        <span class="review-name">${r.name}</span>
        <span class="review-date">${r.date}</span>
      </div>
      <div style="margin-bottom:6px;">${starsSVG(r.score, 12, false)}</div>
      <div class="review-text">${r.text}</div>
    </div>`).join("");

  document.getElementById("detailContent").innerHTML = `
    <div class="detail-hero" style="background:${g.bg};">
      <i class="ti ${g.icon}"></i>
    </div>
    <div class="detail-title">${g.title}</div>
    <div class="detail-badges">
      ${g.genres.map(gn => `<span class="badge ${badgeClass[gn]||''}">${gn}</span>`).join("")}
    </div>
    <div class="detail-meta">
      <div class="meta-box">
        ${starsSVG(g.score, 16, true)}
        <div class="meta-val">${g.score.toFixed(1)}</div>
        <div class="meta-label">Durchschnitt</div>
      </div>
      <div class="meta-box">
        <div class="meta-val">${fmt(g.votes)}</div>
        <div class="meta-label">Bewertungen</div>
      </div>
      <div class="meta-box">
        <div class="meta-val">#${rank}</div>
        <div class="meta-label">Ranking</div>
      </div>
    </div>
    <div class="detail-info">
      <div class="info-box"><div class="info-label">Entwickler</div><div class="info-val">${g.developer}</div></div>
      <div class="info-box"><div class="info-label">Publisher</div><div class="info-val">${g.publisher}</div></div>
      <div class="info-box"><div class="info-label">Erscheinungsjahr</div><div class="info-val">${g.year}</div></div>
      <div class="info-box"><div class="info-label">Plattformen</div><div class="info-val">${g.platforms}</div></div>
    </div>
    <div class="section">
      <h3>Über das Spiel</h3>
      <div class="desc">${g.desc}</div>
    </div>
    <div class="section">
      <h3>Nutzerrezensionen (${g.reviews.length})</h3>
      <div class="review-list">${reviews}</div>
    </div>`;
}

function render() {
  const query = document.getElementById("searchInput").value.trim().toLowerCase();
  const sort  = document.getElementById("sortSelect").value;

  let list = activeGenre === "all" ? [...games] : games.filter(g => g.genres.includes(activeGenre));
  if (query) list = list.filter(g =>
    g.title.toLowerCase().includes(query) ||
    g.genres.some(gn => gn.toLowerCase().includes(query))
  );
  if (sort === "desc")       list.sort((a,b) => b.score - a.score);
  else if (sort === "asc")   list.sort((a,b) => a.score - b.score);
  else if (sort === "votes") list.sort((a,b) => b.votes - a.votes);

  const grid = document.getElementById("gameGrid");
  if (!list.length) { grid.innerHTML = '<p class="empty">Keine Spiele gefunden.</p>'; return; }

  grid.innerHTML = list.map(g => {
    const idx = games.indexOf(g);
    return `
      <div class="card" onclick="openGame(${idx})">
        <div class="card-img" style="background:${g.bg};color:#fff;">
          <i class="ti ${g.icon}"></i>
        </div>
        <div class="card-body">
          <div class="card-title">${g.title}</div>
          <div class="badges">
            ${g.genres.map(gn => `<span class="badge ${badgeClass[gn]||''}">${gn}</span>`).join("")}
          </div>
          <div class="rating">
            ${starsSVG(g.score, 12, false)}
            <span class="score">${g.score.toFixed(1)}</span>
          </div>
          <div class="count">${fmt(g.votes)} Bewertungen</div>
        </div>
      </div>`;
  }).join("");
}

function filterGenre(el, genre) {
  document.querySelectorAll(".genre-chip").forEach(c => c.classList.remove("active"));
  el.classList.add("active");
  activeGenre = genre;
  render();
}

render();
</script>
</body>
</html>