@page "/"
@rendermode InteractiveServer 
@using Backloggd.Models
@using Backloggd.Services

@inject DataService DataService

<style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    :root {
      --color-bg: #f9f9f8;
      --color-surface: #ffffff;
      --color-border: #e4e4e0;
      --color-border-light: #eeeeea;
      --color-text-primary: #111110;
      --color-text-secondary: #6b6b68;
      --color-text-tertiary: #a8a8a4;
      --color-accent: #E24B4A;
      --radius-sm: 6px;
      --radius-md: 10px;
      --radius-lg: 14px;
    }

    body {
      background: var(--color-bg);
      color: var(--color-text-primary);
      font-family: 'Georgia', serif;
      min-height: 100vh;
      padding: 0 20px 60px;
      max-width: 1100px;
      margin: 0 auto;
    }

    /* HEADER */
    .header {
      padding: 2rem 0 1.5rem;
      border-bottom: 0.5px solid var(--color-border);
      margin-bottom: 1.5rem;
      display: flex;
      align-items: center;
      justify-content: space-between;
    }
    .logo {
      font-size: 24px;
      font-weight: 700;
      color: var(--color-text-primary);
      letter-spacing: -0.5px;
      font-family: 'Georgia', serif;
      text-decoration: none;
    }
    .logo span { color: var(--color-accent); }
    .tagline { font-size: 13px; color: var(--color-text-secondary); margin-top: 3px; font-family: sans-serif; }

    /* TOOLBAR */
    .toolbar {
      display: flex;
      gap: 10px;
      align-items: center;
      margin-bottom: 1rem;
      flex-wrap: wrap;
    }
    .search-wrap {
      display: flex;
      align-items: center;
      gap: 8px;
      flex: 1;
      min-width: 160px;
      border: 0.5px solid var(--color-border);
      border-radius: var(--radius-md);
      padding: 0 12px;
      height: 38px;
      background: var(--color-surface);
    }
    .search-wrap svg { flex-shrink: 0; color: var(--color-text-tertiary); }
    .search-wrap input {
      border: none;
      outline: none;
      background: transparent;
      font-size: 13px;
      color: var(--color-text-primary);
      width: 100%;
      padding: 0;
      height: 100%;
      font-family: sans-serif;
    }
    .search-wrap input::placeholder { color: var(--color-text-tertiary); }
    .sort-select {
      font-size: 11px;
      padding: 0 10px;
      height: 30px;
      border-radius: var(--radius-md);
      border: 0.5px solid var(--color-border);
      background: var(--color-surface);
      color: var(--color-text-secondary);
      cursor: pointer;
      font-family: sans-serif;
    }

    /* GENRE BAR */
    .genre-bar {
      display: flex;
      gap: 8px;
      flex-wrap: wrap;
      margin-bottom: 1.5rem;
    }
    .genre-chip {
      font-size: 12px;
      padding: 5px 13px;
      border-radius: 99px;
      border: 0.5px solid var(--color-border);
      background: var(--color-surface);
      color: var(--color-text-secondary);
      cursor: pointer;
      transition: all 0.15s;
      font-family: sans-serif;
    }
    .genre-chip:hover { border-color: var(--color-text-secondary); color: var(--color-text-primary); }
    .genre-chip.active { background: var(--color-text-primary); color: #fff; border-color: var(--color-text-primary); }

    /* GRID */
    .grid {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(190px, 1fr));
      gap: 16px;
    }
    .empty { font-size: 14px; color: var(--color-text-secondary); padding: 2rem 0; font-family: sans-serif; }

    /* CARD */
    .card {
      background: var(--color-surface);
      border: 0.5px solid var(--color-border-light);
      border-radius: var(--radius-lg);
      overflow: hidden;
      cursor: pointer;
      transition: border-color 0.15s, transform 0.15s, box-shadow 0.15s;
      display: flex;
      flex-direction: column;
    }
    .card:hover {
      border-color: var(--color-border);
      transform: translateY(-2px);
      box-shadow: 0 4px 16px rgba(0,0,0,0.07);
    }
    .card-img {
      width: 100%;
      height: 220px;
      flex-shrink: 0;
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 56px;
    }
    .card-body { padding: 8px 10px 10px; flex-shrink: 0; }
    .card-title {
      font-size: 13px;
      font-weight: 600;
      color: var(--color-text-primary);
      margin-bottom: 5px;
      white-space: nowrap;
      overflow: hidden;
      text-overflow: ellipsis;
      font-family: sans-serif;
    }
    .badges { display: flex; flex-wrap: wrap; gap: 3px; height: 40px; align-content: flex-start; overflow: hidden; margin-bottom: 5px; }
    .badge { font-size: 10px; padding: 2px 6px; border-radius: 4px; font-weight: 500; white-space: nowrap; line-height: 1.6; font-family: sans-serif;  background: #EEEDFE; color: #3C3489;}
    .rating { border-top: 0.5px solid var(--color-border-light); padding-top: 5px; display: flex; align-items: center; gap: 6px; }
    .score { font-size: 12px; font-weight: 600; color: var(--color-text-primary); font-family: sans-serif; }
    .count { font-size: 11px; color: var(--color-text-tertiary); margin-top: 3px; font-family: sans-serif; }

    /* DETAIL PAGE */
    #detailPage { display: none; }
    .back-btn {
      display: flex;
      align-items: center;
      gap: 5px;
      font-size: 12px;
      color: var(--color-text-secondary);
      cursor: pointer;
      padding: 5px 10px;
      border: 0.5px solid var(--color-border);
      border-radius: 99px;
      transition: all 0.15s;
      font-family: sans-serif;
      background: var(--color-surface);
    }
    .back-btn:hover { color: var(--color-text-primary); border-color: var(--color-text-secondary); }
    .detail-hero {
      width: 100%;
      height: 280px;
      border-radius: var(--radius-lg);
      display: flex;
      align-items: center;
      justify-content: center;
      margin-bottom: 1.5rem;
    }
    .detail-hero i { font-size: 96px; color: #fff; }
    .detail-title { font-size: 28px; font-weight: 700; color: var(--color-text-primary); margin-bottom: 8px; }
    .detail-badges { display: flex; gap: 6px; flex-wrap: wrap; margin-bottom: 16px; }
    .detail-badges .badge { font-size: 11px; padding: 3px 10px; }
    .detail-meta { display: grid; grid-template-columns: repeat(3, 1fr); gap: 12px; margin-bottom: 12px; }
    .detail-info { display: grid; grid-template-columns: repeat(2, 1fr); gap: 12px; margin-bottom: 1.5rem; }
    .meta-box {
      background: var(--color-surface);
      border: 0.5px solid var(--color-border-light);
      border-radius: var(--radius-lg);
      padding: 14px;
      display: flex;
      flex-direction: column;
      align-items: center;
      text-align: center;
      gap: 4px;
    }
    .meta-val { font-size: 22px; font-weight: 700; color: var(--color-text-primary); font-family: sans-serif; }
    .meta-label { font-size: 11px; color: var(--color-text-tertiary); font-family: sans-serif; }
    .info-box { background: var(--color-surface); border: 0.5px solid var(--color-border-light); border-radius: var(--radius-lg); padding: 12px 14px; }
    .info-label { font-size: 10px; color: var(--color-text-tertiary); text-transform: uppercase; letter-spacing: 0.5px; margin-bottom: 4px; font-family: sans-serif; }
    .info-val { font-size: 13px; font-weight: 500; color: var(--color-text-primary); font-family: sans-serif; }
    .section { margin-bottom: 1.5rem; }
    .section h3 { font-size: 14px; font-weight: 600; color: var(--color-text-primary); margin-bottom: 10px; padding-bottom: 6px; border-bottom: 0.5px solid var(--color-border-light); font-family: sans-serif; }
    .desc { font-size: 13px; color: var(--color-text-secondary); line-height: 1.8; font-family: sans-serif; }
    .review-list { display: flex; flex-direction: column; gap: 10px; }
    .review { background: var(--color-surface); border: 0.5px solid var(--color-border-light); border-radius: var(--radius-lg); padding: 12px 14px; }
    .review-top { display: flex; align-items: center; gap: 8px; margin-bottom: 6px; }
    .avatar { width: 30px; height: 30px; border-radius: 99px; background: var(--color-border-light); display: flex; align-items: center; justify-content: center; font-size: 13px; font-weight: 600; color: var(--color-text-secondary); flex-shrink: 0; font-family: sans-serif; }
    .review-name { font-size: 13px; font-weight: 500; color: var(--color-text-primary); font-family: sans-serif; }
    .review-date { font-size: 11px; color: var(--color-text-tertiary); margin-left: auto; font-family: sans-serif; }
    .review-text { font-size: 12px; color: var(--color-text-secondary); line-height: 1.6; margin-top: 6px; font-family: sans-serif; }

    /* BADGE COLORS */
    /* .b-rpg    { background: #EEEDFE; color: #3C3489; }  */

   /*  .b-action { background: #FCEBEB; color: #791F1F; }
    .b-strat  { background: #E6F1FB; color: #0C447C; }
    .b-adv    { background: #EAF3DE; color: #27500A; }
    .b-sport  { background: #FAEEDA; color: #633806; }
    .b-horror { background: #FBEAF0; color: #72243E; }
    .b-open   { background: #E1F5EE; color: #085041; }
    .b-indie  { background: #FAECE7; color: #712B13; } */
</style>


@if (ausgewaehltes_Spiel == null)
{
    <!-- HOME PAGE -->
    <div class="header">
        <div class="logo">Back<span>loggd</span></div>
    </div>

    <div class="genre-chips">
        <span class="genre-chip @(aktivesGenre == "all" ? "active" : "")"
              @onclick='() => FilterGenre("all")'>Alle</span>
        @foreach (var genre in alleGenres)
        {
            <span class="genre-chip @(aktivesGenre == genre ? "active" : "")"
                  @onclick="() => FilterGenre(genre)">@genre</span>
        }
    </div>

    <div class="search-sort">
        @* <input class="form-control" placeholder="Suchen…"
               @bind="suchbegriff" @bind:event="oninput" @oninput="Filtern" /> *@
        <input value="@suchbegriff" @oninput="e => { suchbegriff = e.Value?.ToString(); Filtern(); }" />
        <select class="form-select" @bind="sortierung" @bind:after="Filtern">
            <option value="">Standard</option>
            <option value="desc">Beste zuerst</option>
            <option value="asc">Schlechteste zuerst</option>
            <option value="votes">Meiste Bewertungen</option>
        </select>
    </div>

    <div class="game-grid">
        @if (!gefilterteSpiele.Any())
        {
            <p class="empty">Keine Spiele gefunden.</p>
        }
        else
        {
            @foreach (var spiel in gefilterteSpiele)
            {
                <div class="card" @onclick="() => SpielOeffnen(spiel)">
                    <div class="card-img">
                        <i class="ti ti-device-gamepad-2"></i>
                    </div>
                    <div class="card-body">
                        <div class="card-title">@spiel.Titel</div>
                        <div class="badges">
                            @foreach (var genre in spiel.Genre.Split(',', StringSplitOptions.TrimEntries))
                            {
                               @*  <span class="badge b-@genre.ToLower().Replace(" ", "")">@genre</span> *@ @* interaktive badge farben was eher schwer ist umzusetzen weil hardcoded sein muss *@
                            <span class="badge b-default.ToLower().Replace(" ", "")">@genre</span>
                            }
                        </div>
                        <div class="rating">
                           @*  @StarsSVG(BewertungBerechnen(spiel), 12) *@
                           <StarsSVG Score="@BewertungBerechnen(spiel)" />
                            <span class="score">@BewertungBerechnen(spiel).ToString("F1")</span>
                        </div>
                        <div class="count">@spiel.ReviewsDesSpiels?.Count Bewertungen</div>
                    </div>
                </div>
            }
        }
    </div>
}
else
{
    <!-- DETAIL PAGE -->
    <div class="header">
        <div class="logo">Back<span>loggd</span></div>
        <div class="back-btn" @onclick="ZurueckZurUebersicht">
            <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"
                 stroke-linecap="round" stroke-linejoin="round">
                <polyline points="15 18 9 12 15 6"/>
            </svg>
            Zurück
        </div>
    </div>

    <div class="detail-content">
        <div class="detail-img">
            <i class="ti ti-device-gamepad-2"></i>
        </div>
        <h1>@ausgewaehltes_Spiel.Titel</h1>

        <div class="badges">
            @foreach (var genre in ausgewaehltes_Spiel.Genre.Split(',', StringSplitOptions.TrimEntries))
            {
                <span class="badge">@genre</span>
            }
        </div>

        <div class="rating">
           @*  @((MarkupString)StarsSVG(BewertungBerechnen(ausgewaehltes_Spiel) , 16))*@
           <StarsSVG Score="@BewertungBerechnen(ausgewaehltes_Spiel)" />
            <span class="score">@BewertungBerechnen(ausgewaehltes_Spiel).ToString("F1")</span>
            <span class="count">(@ausgewaehltes_Spiel.ReviewsDesSpiels?.Count Bewertungen)</span>
        </div>

        <div class="meta">
            <span><b>Entwickler:</b> @ausgewaehltes_Spiel.Entwickler</span>
            <span><b>Publisher:</b> @ausgewaehltes_Spiel.Publisher</span>
            <span><b>Release:</b> @ausgewaehltes_Spiel.Release</span>
        </div>

        <p class="desc">@ausgewaehltes_Spiel.Beschreibung</p>

        <h2>Bewertungen</h2>

        <div class="review-form">
            <h3>Bewertung schreiben</h3>
            <EditForm Model="@neueReview" OnValidSubmit="HandleSubmit" FormName="ReviewForm">
                <DataAnnotationsValidator />

                <div class="mb-3">
                    <label for="username" class="form-label">Dein User</label>
                    <InputText id="username" class="form-control" @bind-Value="neueReview.User" placeholder="z.B. SoulsFan92" />
                    <ValidationMessage For="@(() => neueReview.User)" class="text-danger small" />
                </div>

                <div class="mb-3">
                    <label class="form-label">Bewertung: <strong>@neueReview.Rating</strong> / 100</label>
                    <input type="range" class="form-range" min="1" max="100"
                           @bind="neueReview.Rating" @bind:event="oninput" />
                    <div class="d-flex justify-content-between small text-muted">
                        <span>1</span>
                        <StarsSVG Score="@(neueReview.Rating / 20.0)" />
                        <span>100</span>
                    </div>
                </div>

                <div class="mb-3">
                    <label for="reviewtext" class="form-label">Deine Bewertung</label>
                    <InputTextArea id="reviewtext" class="form-control" @bind-Value="neueReview.ReviewText"
                                   placeholder="Was denkst du über dieses Spiel?" rows="4" />
                    <ValidationMessage For="@(() => neueReview.ReviewText)" class="text-danger small" />
                </div>

                @if (erfolgreich)
                {
                    <div class="alert alert-success">Bewertung erfolgreich gespeichert!</div>
                }

                <div class="d-flex justify-content-end">
                    <button type="submit" class="btn btn-primary">Bewertung abschicken</button>
                </div>
            </EditForm>
        </div>


        @if (ausgewaehltes_Spiel.ReviewsDesSpiels == null || !ausgewaehltes_Spiel.ReviewsDesSpiels.Any())
        {
           


            <p>Noch keine Bewertungen.</p>
        }
        else
        {

            @* nach der @foreach Review-Schleife *@
            

            @foreach (var review in ausgewaehltes_Spiel.ReviewsDesSpiels)
            {
                <div class="review-card">
                    <div class="review-header">
                        <span class="review-user">@review.User</span>
                        <div class="rating">
                            @* @((MarkupString)StarsSVG(review.Rating / 20.0, 12)) *@
                            <StarsSVG Score="@(review.Rating / 20.0)" />
                            <span class="score">@((review.Rating / 20.0).ToString("F1"))</span>
                        </div>
                    </div>
                    <p class="review-text">@review.ReviewText</p>
                </div>
            }




        }
    </div>
}

@inject NavigationManager NavigationManager
@inject DataService mydataService
@code {
    private List<Spiel> alleSpiele = new();
    private List<Spiel> gefilterteSpiele = new();
    private List<string> alleGenres = new();
    private Spiel? ausgewaehltes_Spiel = null;
    private string suchbegriff = "";
    private string sortierung = "";
    private string aktivesGenre = "all";

    protected override void OnInitialized()
    {
        // Spiele aus der Datenbank laden — passe den Aufruf an deinen Service an:
        var (spiele, erfolg) = mydataService.GetAlleSpiele(); // ← deinen Methodennamen einsetzen
        if (erfolg && spiele != null)
        {
            alleSpiele = spiele;
            alleGenres = alleSpiele
                .SelectMany(s => s.Genre.Split(',', StringSplitOptions.TrimEntries))
                .Distinct()
                .OrderBy(g => g)
                .ToList();
        }
        gefilterteSpiele = new List<Spiel>(alleSpiele);
    }

    // private double BewertungBerechnen(Spiel spiel)
    // {
    //     if (spiel.ReviewsDesSpiels == null || !spiel.ReviewsDesSpiels.Any())
    //         return 0;
    //     // Rating ist 1–100, wir rechnen auf 0–5 um
    //     return spiel.ReviewsDesSpiels.Average(r => r.Rating) / 20.0;
    // }

    private double BewertungBerechnen(Spiel spiel)
    {
        // Wenn Reviews geladen sind, live berechnen
        if (spiel.ReviewsDesSpiels != null && spiel.ReviewsDesSpiels.Any())
            return spiel.ReviewsDesSpiels.Average(r => r.Rating) / 20.0;

        // Sonst gespeicherten Durchschnitt aus DB nehmen (für die Kartenliste)
        return (double)spiel.DurchschnittsBewertung / 20.0;
    }

    private void Filtern()
    {
        var liste = aktivesGenre == "all"
            ? new List<Spiel>(alleSpiele)
            : alleSpiele.Where(s => s.Genre.Contains(aktivesGenre)).ToList();

        if (!string.IsNullOrWhiteSpace(suchbegriff))
            liste = liste.Where(s =>
                s.Titel.Contains(suchbegriff, StringComparison.OrdinalIgnoreCase) ||
                s.Genre.Contains(suchbegriff, StringComparison.OrdinalIgnoreCase)).ToList();

        liste = sortierung switch
        {
            "desc"  => liste.OrderByDescending(s => BewertungBerechnen(s)).ToList(),
            "asc"   => liste.OrderBy(s => BewertungBerechnen(s)).ToList(),
            "votes" => liste.OrderByDescending(s => s.ReviewsDesSpiels?.Count ?? 0).ToList(),
            _       => liste
        };

        gefilterteSpiele = liste;
    }

    private void FilterGenre(string genre)
    {
        aktivesGenre = genre;
        Filtern();
    }

    private void SpielOeffnen(Spiel spiel)
    {
        ausgewaehltes_Spiel = DataService.GetSpielFromDatabase(spiel.SpielId);
    }

    private void ZurueckZurUebersicht()
    {
        ausgewaehltes_Spiel = null;
    }

