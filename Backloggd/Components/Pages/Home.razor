let activeGenre = "all";
let uid = 0;
const STAR_PATH = "M6,1.5 L7.27,4.64 L10.5,4.64 L7.95,6.61 L8.9,9.75 L6,7.9 L3.1,9.75 L4.05,6.61 L1.5,4.64 L4.73,4.64 Z";

function starsSVG(score, size, centered) {
  size = size || 12;
  const sp = size * 1.3;
  const id = "sg" + (uid++);
  let defs = "<defs>";
  for (let i = 1; i <= 5; i++) {
    const pct = (Math.min(1, Math.max(0, score-(i-1))) * 100).toFixed(1);
    defs += `<linearGradient id="${id}g${i}" x1="0" x2="1" y1="0" y2="0">
      <stop offset="${pct}%" stop-color="#EF9F27"/>
      <stop offset="${pct}%" stop-color="#D3D1C7"/>
    </linearGradient>`;
  }
  defs += "</defs>";
  const sc = size / 12;
  let s = "";
  for (let i = 1; i <= 5; i++)
    s += `<path d="${STAR_PATH}" transform="translate(${(i-1)*sp},0) scale(${sc})" fill="url(#${id}g${i})"/>`;
  const w = 4 * sp + size;
  const margin = centered ? "margin:0 auto;" : "margin:0;";
  return `<svg width="${w}" height="${size}" viewBox="0 0 ${w} ${size}" style="display:block;${margin}overflow:visible;">${defs}${s}</svg>`;
}

function fmt(n) { return n >= 1000 ? (n/1000).toFixed(1) + "k" : n; }

function goHome() {
  document.getElementById("homePage").style.display = "";
