@page "/"
@rendermode InteractiveServer 
@using Backloggd.Models
@using Backloggd.Services

@inject DataService DataService

@* <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    :root {
      --color-bg: #f9f9f8;
      --color-surface: #ffffff;
      --color-border: #e4e4e0;
      --color-border-light: #eeeeea;
      --color-text-primary: #111110;
      --color-text-secondary: #6b6b68;
      --color-text-tertiary: #a8a8a4;
      --color-accent: #E24B4A;
      --radius-sm: 6px;
      --radius-md: 10px;
      --radius-lg: 14px;
    }

    body {
      background: var(--color-bg);
      color: var(--color-text-primary);
      font-family: 'Georgia', serif;
      min-height: 100vh;
      padding: 0 20px 60px;
      max-width: 1100px;
      margin: 0 auto;
    }

    /* HEADER */
    .header {
      padding: 2rem 0 1.5rem;
      border-bottom: 0.5px solid var(--color-border);
      margin-bottom: 1.5rem;
      display: flex;
      align-items: center;
      justify-content: space-between;
    }
    .logo {
      font-size: 24px;
      font-weight: 700;
      color: var(--color-text-primary);
      letter-spacing: -0.5px;
      font-family: 'Georgia', serif;
      text-decoration: none;
    }
    .logo span { color: var(--color-accent); }
    .tagline { font-size: 13px; color: var(--color-text-secondary); margin-top: 3px; font-family: sans-serif; }

    /* TOOLBAR */
    .toolbar {
      display: flex;
      gap: 10px;
      align-items: center;
      margin-bottom: 1rem;
      flex-wrap: wrap;
    }
    .search-wrap {
      display: flex;
      align-items: center;
      gap: 8px;
      flex: 1;
      min-width: 160px;
      border: 0.5px solid var(--color-border);
      border-radius: var(--radius-md);
      padding: 0 12px;
      height: 38px;
      background: var(--color-surface);
    }
    .search-wrap svg { flex-shrink: 0; color: var(--color-text-tertiary); }
    .search-wrap input {
      border: none;
      outline: none;
      background: transparent;
      font-size: 13px;
      color: var(--color-text-primary);
      width: 100%;
      padding: 0;
      height: 100%;
      font-family: sans-serif;
    }
    .search-wrap input::placeholder { color: var(--color-text-tertiary); }
    .sort-select {
      font-size: 11px;
      padding: 0 10px;
      height: 30px;
      border-radius: var(--radius-md);
      border: 0.5px solid var(--color-border);
      background: var(--color-surface);
      color: var(--color-text-secondary);
      cursor: pointer;
      font-family: sans-serif;
    }

    /* GENRE BAR */
    .genre-bar {
      display: flex;
      gap: 8px;
      flex-wrap: wrap;
      margin-bottom: 1.5rem;
    }
    .genre-chip {
      font-size: 12px;
      padding: 5px 13px;
      border-radius: 99px;
      border: 0.5px solid var(--color-border);
      background: var(--color-surface);
      color: var(--color-text-secondary);
      cursor: pointer;
      transition: all 0.15s;
      font-family: sans-serif;
    }
    .genre-chip:hover { border-color: var(--color-text-secondary); color: var(--color-text-primary); }
    .genre-chip.active { background: var(--color-text-primary); color: #fff; border-color: var(--color-text-primary); }

    /* GRID */
    .grid {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(190px, 1fr));
      gap: 16px;
    }
    .empty { font-size: 14px; color: var(--color-text-secondary); padding: 2rem 0; font-family: sans-serif; }

    /* CARD */
    .card {
      background: var(--color-surface);
      border: 0.5px solid var(--color-border-light);
      border-radius: var(--radius-lg);
      overflow: hidden;
      cursor: pointer;
      transition: border-color 0.15s, transform 0.15s, box-shadow 0.15s;
      display: flex;
      flex-direction: column;
    }
    .card:hover {
      border-color: var(--color-border);
      transform: translateY(-2px);
      box-shadow: 0 4px 16px rgba(0,0,0,0.07);
    }

    .card-img {
        width: 100%;
        height: 220px;
        flex-shrink: 0;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 56px;
        overflow: hidden;
    }

    .card-img img {
            width: 100%;
            height: 100%;
            object-fit: cover;
    }

    .card-body { padding: 8px 10px 10px; flex-shrink: 0; }
    .card-title {
      font-size: 13px;
      font-weight: 600;
      color: var(--color-text-primary);
      margin-bottom: 5px;
      white-space: nowrap;
      overflow: hidden;
      text-overflow: ellipsis;
      font-family: sans-serif;
    }
    .badges { display: flex; flex-wrap: wrap; gap: 3px; height: 40px; align-content: flex-start; overflow: hidden; margin-bottom: 5px; }
    .badge { font-size: 10px; padding: 2px 6px; border-radius: 4px; font-weight: 500; white-space: nowrap; line-height: 1.6; font-family: sans-serif;  background: #EEEDFE; color: #3C3489;}
    .rating { border-top: 0.5px solid var(--color-border-light); padding-top: 5px; display: flex; align-items: center; gap: 6px; }
    .score { font-size: 12px; font-weight: 600; color: var(--color-text-primary); font-family: sans-serif; }
    .count { font-size: 11px; color: var(--color-text-tertiary); margin-top: 3px; font-family: sans-serif; }

    /* DETAIL PAGE */
    #detailPage { display: none; }
    .back-btn {
      display: flex;
      align-items: center;
      gap: 5px;
      font-size: 12px;
      color: var(--color-text-secondary);
      cursor: pointer;
      padding: 5px 10px;
      border: 0.5px solid var(--color-border);
      border-radius: 99px;
      transition: all 0.15s;
      font-family: sans-serif;
      background: var(--color-surface);
    }
    .back-btn:hover { color: var(--color-text-primary); border-color: var(--color-text-secondary); }
    .detail-hero {
      width: 100%;
      height: 280px;
      border-radius: var(--radius-lg);
      display: flex;
      align-items: center;
      justify-content: center;
      margin-bottom: 1.5rem;
    }
    .detail-hero i { font-size: 96px; color: #fff; }
    .detail-title { font-size: 28px; font-weight: 700; color: var(--color-text-primary); margin-bottom: 8px; }
    .detail-badges { display: flex; gap: 6px; flex-wrap: wrap; margin-bottom: 16px; }
    .detail-badges .badge { font-size: 11px; padding: 3px 10px; }
    .detail-meta { display: grid; grid-template-columns: repeat(3, 1fr); gap: 12px; margin-bottom: 12px; }
    .detail-info { display: grid; grid-template-columns: repeat(2, 1fr); gap: 12px; margin-bottom: 1.5rem; }
    .meta-box {
      background: var(--color-surface);
      border: 0.5px solid var(--color-border-light);
      border-radius: var(--radius-lg);
      padding: 14px;
      display: flex;
      flex-direction: column;
      align-items: center;
      text-align: center;
      gap: 4px;
    }
    .meta-val { font-size: 22px; font-weight: 700; color: var(--color-text-primary); font-family: sans-serif; }
    .meta-label { font-size: 11px; color: var(--color-text-tertiary); font-family: sans-serif; }
    .info-box { background: var(--color-surface); border: 0.5px solid var(--color-border-light); border-radius: var(--radius-lg); padding: 12px 14px; }
    .info-label { font-size: 10px; color: var(--color-text-tertiary); text-transform: uppercase; letter-spacing: 0.5px; margin-bottom: 4px; font-family: sans-serif; }
    .info-val { font-size: 13px; font-weight: 500; color: var(--color-text-primary); font-family: sans-serif; }
    .section { margin-bottom: 1.5rem; }
    .section h3 { font-size: 14px; font-weight: 600; color: var(--color-text-primary); margin-bottom: 10px; padding-bottom: 6px; border-bottom: 0.5px solid var(--color-border-light); font-family: sans-serif; }
    .desc { font-size: 13px; color: var(--color-text-secondary); line-height: 1.8; font-family: sans-serif; }
    .review-list { display: flex; flex-direction: column; gap: 10px; }
    .review { background: var(--color-surface); border: 0.5px solid var(--color-border-light); border-radius: var(--radius-lg); padding: 12px 14px; }
    .review-top { display: flex; align-items: center; gap: 8px; margin-bottom: 6px; }
    .avatar { width: 30px; height: 30px; border-radius: 99px; background: var(--color-border-light); display: flex; align-items: center; justify-content: center; font-size: 13px; font-weight: 600; color: var(--color-text-secondary); flex-shrink: 0; font-family: sans-serif; }
    .review-name { font-size: 13px; font-weight: 500; color: var(--color-text-primary); font-family: sans-serif; }
    .review-date { font-size: 11px; color: var(--color-text-tertiary); margin-left: auto; font-family: sans-serif; }
    .review-text { font-size: 12px; color: var(--color-text-secondary); line-height: 1.6; margin-top: 6px; font-family: sans-serif; }

    /* BADGE COLORS */
    /* .b-rpg    { background: #EEEDFE; color: #3C3489; }  */

   /*  .b-action { background: #FCEBEB; color: #791F1F; }
    .b-strat  { background: #E6F1FB; color: #0C447C; }
    .b-adv    { background: #EAF3DE; color: #27500A; }
    .b-sport  { background: #FAEEDA; color: #633806; }
    .b-horror { background: #FBEAF0; color: #72243E; }
    .b-open   { background: #E1F5EE; color: #085041; }
    .b-indie  { background: #FAECE7; color: #712B13; } */
</style> *@

<style>
    *, *::before, *::after {
        box-sizing: border-box;
        margin: 0;
        padding: 0;
    }

    :root {
        --bg: #0f0f13;
        --surface: #1a1a23;
        --surface2: #22222e;
        --border: #2e2e3d;
        --border-light: #252532;
        --text-primary: #f0f0f5;
        --text-secondary: #9090a8;
        --text-tertiary: #55556a;
        --accent: #7c6af7;
        --accent-hover: #9282ff;
        --accent-soft: rgba(124,106,247,0.15);
        --gold: #EF9F27;
        --success: #3ecf8e;
        --danger: #f87171;
        --radius-sm: 6px;
        --radius-md: 10px;
        --radius-lg: 14px;
        --radius-xl: 18px;
    }

    body {
        background: var(--bg);
        color: var(--text-primary);
        font-family: 'Inter', 'Segoe UI', sans-serif;
        min-height: 100vh;
        padding: 0 24px 80px;
        max-width: 1200px;
        margin: 0 auto;
    }

    /* ── HEADER ── */
    .header {
        padding: 1.75rem 0 1.25rem;
        border-bottom: 0.5px solid var(--border);
        margin-bottom: 1.75rem;
        display: flex;
        align-items: center;
        justify-content: space-between;
    }

    .logo {
        font-size: 22px;
        font-weight: 800;
        color: var(--text-primary);
        letter-spacing: -0.5px;
        font-family: 'Georgia', serif;
    }

        .logo span {
            color: var(--accent);
        }

    .back-btn {
        display: flex;
        align-items: center;
        gap: 6px;
        font-size: 12px;
        color: var(--text-secondary);
        cursor: pointer;
        padding: 6px 14px;
        border: 0.5px solid var(--border);
        border-radius: 99px;
        background: var(--surface);
        transition: all 0.15s;
    }

        .back-btn:hover {
            color: var(--text-primary);
            border-color: var(--accent);
            background: var(--accent-soft);
        }

    /* ── SEARCH & SORT ── */
    .search-sort {
        display: flex;
        gap: 10px;
        margin-bottom: 1.25rem;
        flex-wrap: wrap;
    }

        .search-sort input {
            flex: 1;
            min-width: 180px;
            background: var(--surface);
            border: 0.5px solid var(--border);
            border-radius: var(--radius-md);
            padding: 0 14px;
            height: 40px;
            font-size: 13px;
            color: var(--text-primary);
            outline: none;
            transition: border-color 0.15s;
        }

            .search-sort input::placeholder {
                color: var(--text-tertiary);
            }

            .search-sort input:focus {
                border-color: var(--accent);
            }

        .search-sort select, .form-select {
            background: var(--surface);
            border: 0.5px solid var(--border);
            border-radius: var(--radius-md);
            padding: 0 14px;
            height: 40px;
            font-size: 12px;
            color: var(--text-secondary);
            cursor: pointer;
            outline: none;
            transition: border-color 0.15s;
        }

            .search-sort select:focus {
                border-color: var(--accent);
            }

    /* ── GENRE CHIPS ── */
    .genre-chips {
        display: flex;
        gap: 8px;
        flex-wrap: wrap;
        margin-bottom: 1.5rem;
    }

    .genre-chip {
        font-size: 12px;
        padding: 5px 14px;
        border-radius: 99px;
        border: 0.5px solid var(--border);
        background: var(--surface);
        color: var(--text-secondary);
        cursor: pointer;
        transition: all 0.15s;
    }

        .genre-chip:hover {
            border-color: var(--accent);
            color: var(--text-primary);
            background: var(--accent-soft);
        }

        .genre-chip.active {
            background: var(--accent);
            color: #fff;
            border-color: var(--accent);
        }

    /* ── GRID ── */
    .game-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(200px, 1fr));
        gap: 18px;
    }

    .empty {
        font-size: 14px;
        color: var(--text-secondary);
        padding: 3rem 0;
        grid-column: 1/-1;
        text-align: center;
    }

    /* ── CARD ── */
    .card {
        background: var(--surface);
        border: 0.5px solid var(--border-light);
        border-radius: var(--radius-xl);
        overflow: hidden;
        cursor: pointer;
        transition: border-color 0.15s, transform 0.15s, box-shadow 0.15s;
        display: flex;
        flex-direction: column;
    }

        .card:hover {
            border-color: var(--accent);
            transform: translateY(-3px);
            box-shadow: 0 8px 32px rgba(124,106,247,0.15);
        }

    .card-img {
        width: 100%;
        height: 200px;
        flex-shrink: 0;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 56px;
        color: var(--text-tertiary);
        background: var(--surface2);
        overflow: hidden;
    }

        .card-img img {
            width: 100%;
            height: 100%;
            object-fit: fill;
        }

    .card-body {
        padding: 10px 12px 12px;
        flex: 1;
        display: flex;
        flex-direction: column;
        gap: 6px;
    }

    .card-title {
        font-size: 13px;
        font-weight: 600;
        color: var(--text-primary);
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
    }

    .badges {
        display: flex;
        flex-wrap: wrap;
        gap: 4px;
        min-height: 22px;
    }

    .badge {
        font-size: 10px;
        padding: 2px 8px;
        border-radius: 99px;
        font-weight: 500;
        white-space: nowrap;
        background: var(--accent-soft);
        color: var(--accent-hover);
        border: 0.5px solid rgba(124,106,247,0.25);
    }

    .rating {
        display: flex;
        align-items: center;
        gap: 6px;
        padding-top: 6px;
        border-top: 0.5px solid var(--border-light);
        margin-top: auto;
    }

    .score {
        font-size: 12px;
        font-weight: 700;
        color: var(--gold);
    }

    .count {
        font-size: 11px;
        color: var(--text-tertiary);
    }

    /* ── DETAIL PAGE ── */
    .detail-content {
        display: flex;
        flex-direction: column;
        gap: 1.25rem;
    }

    .detail-top {
        display: grid;
        grid-template-columns: 1fr 300px;
        gap: 24px;
        align-items: start;
    }

    .detail-hero {
        width: 300px;
        height: 300px;
        border-radius: var(--radius-xl);
        overflow: hidden;
        background: var(--surface2);
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 96px;
        color: var(--text-tertiary);
        border: 0.5px solid var(--border);
        flex-shrink: 0;
      
    }

        .detail-hero img {
            width: 100%;
            height: 100%;
            object-fit: fill;
        }

    .detail-content h1 {
        font-size: 28px;
        font-weight: 800;
        color: var(--text-primary);
        letter-spacing: -0.5px;
    }

    .detail-badges {
        display: flex;
        gap: 6px;
        flex-wrap: wrap;
    }

        .detail-badges .badge {
            font-size: 11px;
            padding: 4px 12px;
        }

    /* Meta boxes */
    .meta {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 12px;
    }

        .meta span {
            background: var(--surface);
            border: 0.5px solid var(--border);
            border-radius: var(--radius-lg);
            padding: 14px;
            font-size: 13px;
            color: var(--text-secondary);
            display: flex;
            flex-direction: column;
            gap: 4px;
        }

            .meta span b {
                font-size: 10px;
                text-transform: uppercase;
                letter-spacing: 0.5px;
                color: var(--text-tertiary);
                font-weight: 500;
            }

    .desc {
        font-size: 14px;
        color: var(--text-secondary);
        line-height: 1.8;
        background: var(--surface);
        border: 0.5px solid var(--border);
        border-radius: var(--radius-lg);
        padding: 16px;
    }

    .detail-content h2 {
        font-size: 16px;
        font-weight: 700;
        color: var(--text-primary);
        padding-bottom: 10px;
        border-bottom: 0.5px solid var(--border);
    }

    /* ── REVIEW FORM ── */
    .review-form {
        background: var(--surface);
        border: 0.5px solid var(--border);
        border-radius: var(--radius-xl);
        padding: 20px;
        display: flex;
        flex-direction: column;
        gap: 14px;
    }

        .review-form h3 {
            font-size: 14px;
            font-weight: 600;
            color: var(--text-primary);
            margin-bottom: 4px;
        }

    .mb-3 {
        margin-bottom: 0;
        display: flex;
        flex-direction: column;
        gap: 6px;
    }

    .form-label {
        font-size: 12px;
        color: var(--text-secondary);
        font-weight: 500;
    }

    .form-control, .form-control:focus {
        background: var(--surface2) !important;
        border: 0.5px solid var(--border) !important;
        border-radius: var(--radius-md) !important;
        color: var(--text-primary) !important;
        font-size: 13px !important;
        padding: 10px 14px !important;
        outline: none !important;
        box-shadow: none !important;
        transition: border-color 0.15s !important;
        width: 100%;
    }

        .form-control:focus {
            border-color: var(--accent) !important;
        }

    textarea.form-control {
        resize: vertical;
        min-height: 90px;
    }

    .form-range {
        accent-color: var(--accent);
        width: 100%;
        cursor: pointer;
    }

    .d-flex {
        display: flex;
    }

    .justify-content-between {
        justify-content: space-between;
    }

    .justify-content-end {
        justify-content: flex-end;
    }

    .small {
        font-size: 12px;
    }

    .text-muted {
        color: var(--text-tertiary);
    }

    .align-items-center {
        align-items: center;
    }

    .btn-primary {
        background: var(--accent);
        color: #fff;
        border: none;
        border-radius: var(--radius-md);
        padding: 10px 22px;
        font-size: 13px;
        font-weight: 600;
        cursor: pointer;
        transition: background 0.15s, transform 0.1s;
    }

        .btn-primary:hover {
            background: var(--accent-hover);
            transform: translateY(-1px);
        }

    .alert-success {
        background: rgba(62,207,142,0.1);
        border: 0.5px solid rgba(62,207,142,0.3);
        border-radius: var(--radius-md);
        padding: 10px 14px;
        font-size: 13px;
        color: var(--success);
    }

    .text-danger {
        color: var(--danger) !important;
        font-size: 12px;
    }

    /* ── REVIEW CARDS ── */
    .review-card {
        background: var(--surface);
        border: 0.5px solid var(--border);
        border-radius: var(--radius-lg);
        padding: 14px 16px;
        display: flex;
        flex-direction: column;
        gap: 8px;
        transition: border-color 0.15s;
    }

        .review-card:hover {
            border-color: var(--accent);
        }

    .review-header {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 10px;
    }

    .review-user {
        font-size: 13px;
        font-weight: 600;
        color: var(--text-primary);
        display: flex;
        align-items: center;
        gap: 8px;
    }

        .review-user::before {
            content: '';
            display: inline-block;
            width: 28px;
            height: 28px;
            border-radius: 99px;
            background: var(--accent-soft);
            border: 0.5px solid rgba(124,106,247,0.3);
        }

    .review-text {
        font-size: 13px;
        color: var(--text-secondary);
        line-height: 1.7;
    }

    /* ── DETAIL RATING ── */
    .detail-content .rating {
        border: none;
        padding: 0;
        gap: 8px;
    }

    .detail-content .score {
        font-size: 20px;
    }

    .detail-content .count {
        font-size: 13px;
        color: var(--text-tertiary);
    }

</style>



@if (ausgewaehltes_Spiel == null)
{
    <!-- HOME PAGE -->
    <div class="header">
        <div class="logo">Back<span>loggd</span></div>
    </div>

    <div class="genre-chips">
        <span class="genre-chip @(aktivesGenre == "all" ? "active" : "")"
              @onclick='() => FilterGenre("all")'>Alle</span>
        @foreach (var genre in alleGenres)
        {
            <span class="genre-chip @(aktivesGenre == genre ? "active" : "")"
                  @onclick="() => FilterGenre(genre)">@genre</span>
        }
    </div>

    <div class="search-sort">
        @* <input class="form-control" placeholder="Suchen…"
               @bind="suchbegriff" @bind:event="oninput" @oninput="Filtern" /> *@
        <input placeholder="Suchen..." value="@suchbegriff" @oninput="e => { suchbegriff = e.Value?.ToString(); Filtern(); }" />
        <select class="form-select" @bind="sortierung" @bind:after="Filtern">
            <option value="">Standard</option>
            <option value="desc">Beste zuerst</option>
            <option value="asc">Schlechteste zuerst</option>
            <option value="votes">Meiste Bewertungen</option>
        </select>
    </div>

    <div class="game-grid">

        <a href="/neu" style="text-decoration:none;">
            <div class="card" style="height:100%; min-height:200px; border: 1px dashed var(--accent); background: var(--accent-soft); display:flex; align-items:center; justify-content:center; flex-direction:column; gap:10px;">
                <i class="ti ti-plus" style="font-size:40px; color:var(--accent);"></i>
                <span style="font-size:14px; font-weight:600; color:var(--accent);">Neues Spiel</span>
            </div>
        </a>

        @if (!gefilterteSpiele.Any())
        {
            <p class="empty">Keine Spiele gefunden.</p>
        }
        else
        {
            @foreach (var spiel in gefilterteSpiele)
            {
                <div class="card" @onclick="() => SpielOeffnen(spiel)">
                    <div class="card-img">
                        @if (spiel.Bild != null)
                        {
                            <img src="@($"data:image/jpeg;base64,{Convert.ToBase64String(spiel.Bild)}")" />
                        }
                        else
                        {
                            <i class="ti ti-device-gamepad-2"></i>
                        }
                    </div>
                    <div class="card-body">
                        <div class="card-title">@spiel.Titel</div>
                        <div class="badges">
                            @foreach (var genre in spiel.Genre.Split(',', StringSplitOptions.TrimEntries))
                            {
                               @*  <span class="badge b-@genre.ToLower().Replace(" ", "")">@genre</span> *@ @* interaktive badge farben was eher schwer ist umzusetzen weil hardcoded sein muss *@
                            <span class="badge b-default.ToLower().Replace(" ", "")">@genre</span>
                            }
                        </div>
                        <div class="rating">
                           @*  @StarsSVG(BewertungBerechnen(spiel), 12) *@
                           <StarsSVG Score="@BewertungBerechnen(spiel)" />
                            <span class="score">@BewertungBerechnen(spiel).ToString("F1")</span>
                        </div>
                        <div class="count">@spiel.ReviewsDesSpiels?.Count Bewertungen</div>
                    </div>
                </div>
            }
        }
    </div>
}
