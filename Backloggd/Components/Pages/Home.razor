    //     {
    //         var pct = (Math.Min(1, Math.Max(0, score - (i - 1))) * 100).ToString("F1", System.Globalization.CultureInfo.InvariantCulture);
    //         defs += $@"<linearGradient id=""{id}g{i}"" x1=""0"" x2=""1"" y1=""0"" y2=""0"">
    //             <stop offset=""{pct}%"" stop-color=""#EF9F27""/>
    //             <stop offset=""{pct}%"" stop-color=""#D3D1C7""/>
    //         </linearGradient>";
    //     }
    //     defs += "</defs>";
    //     double sc = size / 12.0;
    //     var stars = "";
    //     for (int i = 1; i <= 5; i++)
    //         stars += $@"<path d=""{PATH}"" transform=""translate({((i - 1) * sp).ToString(System.Globalization.CultureInfo.InvariantCulture)},0) scale({sc.ToString(System.Globalization.CultureInfo.InvariantCulture)})"" fill=""url(#{id}g{i})""/>";
    //     double w = 4 * sp + size;
    //     return $@"<svg width=""{w}"" height=""{size}"" viewBox=""0 0 {w} {size}"" style=""display:block;overflow:visible;"">{defs}{stars}</svg>";
    // }

    private Review neueReview = new() { Rating = 50 };
    private bool erfolgreich = false;

    private async void HandleSubmit()
    {
        neueReview.Spiel = ausgewaehltes_Spiel;
        DataService.ReviewSpeichern(neueReview);

        var geladenesSpiel = DataService.GetSpielFromDatabase(ausgewaehltes_Spiel.SpielId);
        if (geladenesSpiel != null)
            ausgewaehltes_Spiel = geladenesSpiel;

        neueReview = new() { Rating = 50 };
        erfolgreich = true;
        StateHasChanged();

        await Task.Delay(3000); // 3 Sekunden anzeigen
        erfolgreich = false;
        StateHasChanged();
    }
}
