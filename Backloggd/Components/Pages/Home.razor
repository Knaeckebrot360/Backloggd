@code {
    private List<Spiel> alleSpiele = new();
    private List<Spiel> gefilterteSpiele = new();
    private List<string> alleGenres = new();
    private Spiel? ausgewaehltes_Spiel = null;
    private string suchbegriff = "";
    private string sortierung = "";
    private string aktivesGenre = "all";

    protected override void OnInitialized()
    {
        // Spiele aus der Datenbank laden — passe den Aufruf an deinen Service an:
        var (spiele, erfolg) = mydataService.GetAlleSpiele(); // ← deinen Methodennamen einsetzen
        if (erfolg && spiele != null)
        {
            alleSpiele = spiele;
            alleGenres = alleSpiele
                .SelectMany(s => s.Genre.Split(',', StringSplitOptions.TrimEntries))
                .Distinct()
                .OrderBy(g => g)
                .ToList();
        }
        gefilterteSpiele = new List<Spiel>(alleSpiele);
    }

    // private double BewertungBerechnen(Spiel spiel)
    // {
    //     if (spiel.ReviewsDesSpiels == null || !spiel.ReviewsDesSpiels.Any())
    //         return 0;
    //     // Rating ist 1–100, wir rechnen auf 0–5 um
    //     return spiel.ReviewsDesSpiels.Average(r => r.Rating) / 20.0;
    // }

    private double BewertungBerechnen(Spiel spiel)
    {
        // Wenn Reviews geladen sind, live berechnen
        if (spiel.ReviewsDesSpiels != null && spiel.ReviewsDesSpiels.Any())
            return spiel.ReviewsDesSpiels.Average(r => r.Rating) / 20.0;

        // Sonst gespeicherten Durchschnitt aus DB nehmen (für die Kartenliste)
        return (double)spiel.DurchschnittsBewertung / 20.0;
    }

    private void Filtern()
    {
        var liste = aktivesGenre == "all"
            ? new List<Spiel>(alleSpiele)
            : alleSpiele.Where(s => s.Genre.Contains(aktivesGenre)).ToList();

        if (!string.IsNullOrWhiteSpace(suchbegriff))
            liste = liste.Where(s =>
                s.Titel.Contains(suchbegriff, StringComparison.OrdinalIgnoreCase) ||
                s.Genre.Contains(suchbegriff, StringComparison.OrdinalIgnoreCase)).ToList();

        liste = sortierung switch
        {
            "desc"  => liste.OrderByDescending(s => BewertungBerechnen(s)).ToList(),
            "asc"   => liste.OrderBy(s => BewertungBerechnen(s)).ToList(),
            "votes" => liste.OrderByDescending(s => s.ReviewsDesSpiels?.Count ?? 0).ToList(),
            _       => liste
        };

        gefilterteSpiele = liste;
    }

    private void FilterGenre(string genre)
    {
        aktivesGenre = genre;
        Filtern();
    }

    private void SpielOeffnen(Spiel spiel)
    {
        ausgewaehltes_Spiel = DataService.GetSpielFromDatabase(spiel.SpielId);
    }

    private void ZurueckZurUebersicht()
    {
        ausgewaehltes_Spiel = null;
        var (spiele, erfolg) = DataService.GetAlleSpiele();
        if (erfolg && spiele != null)
        {
            alleSpiele = spiele;
            gefilterteSpiele = new List<Spiel>(alleSpiele);
            Filtern();
        }
    }

